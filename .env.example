# Hayati | حياتي - Environment Variables
# Copy this to .env and fill in values

# REQUIRED in production: Secret key for JWT tokens (change this to a random string)
JWT_SECRET=your-random-secret-here-change-me

# Optional: Port (defaults to 3000)
PORT=3000

# Optional: CORS origin (comma-separated for production)
CORS_ORIGIN=http://localhost:3000

# Optional: Set to 'production' for production mode
NODE_ENV=development

# Email (SMTP) - for sending OTP codes to users
# Gmail example (use App Password from Google account):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your.email@gmail.com
#
# If not configured, OTP codes print to console (dev mode only)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

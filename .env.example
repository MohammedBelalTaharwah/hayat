# Hayati | حياتي - Environment Variables
# Copy this to .env and fill in values

# REQUIRED in production: Secret key for JWT tokens (change this to a random string)
JWT_SECRET=your-random-secret-here-change-me

# Optional: Port (defaults to 3000)
PORT=3000

# Optional: CORS origin (comma-separated for production)
CORS_ORIGIN=http://localhost:3000

# Optional: Set to 'production' for production mode
NODE_ENV=development
